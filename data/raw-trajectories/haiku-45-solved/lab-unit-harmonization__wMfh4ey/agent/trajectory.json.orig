ine': (0, 150),  # mg/g\\n    'Urine_Protein': (0, 150),  # mg/dL\\n    'Urine_pH': (4.5, 8.0),  # pH\\n    'Urine_Specific_Gravity': (1.005, 1.030),  # specific gravity\\n    'BNP': (0, 100),  # pg/mL\\n    'NT_proBNP': (0, 125),  # pg/mL\\n    'Troponin_I': (0, 0.04),  # ng/mL\\n    'Troponin_T': (0, 0.04),  # ng/mL\\n    'Free_T4': (0.8, 1.8),  # ng/dL\\n    'Free_T3': (2.3, 4.2),  # pg/mL\\n    'pH_Arterial': (7.35, 7.45),  # pH\\n    'pCO2_Arterial': (35, 45),  # mmHg\\n    'pO2_Arterial': (80, 100),  # mmHg\\n    'Lactate': (0.5, 2.0),  # mmol/L\\n    'Beta2_Microglobulin': (0.7, 3.4),  # mg/L\\n    'Aluminum': (0, 10),  # \u00b5g/L\\n}\\n\\n# Extended conversion factors with more alternatives\\nconversion_factors = {\\n    'Serum_Creatinine': {\\n        '\u00b5mol/L': 1 / 88.4,  # \u00b5mol/L to mg/dL\\n        'mmol/L': 1000 / 88.4,  # mmol/L to mg/dL\\n    },\\n    'BUN': {\\n        'mmol/L': 2.8,  # mmol/L to mg/dL\\n        '\u00b5mol/L': 0.0028,  # \u00b5mol/L to mg/dL\\n    },\\n    'Cystatin_C': {\\n        'mg/dL': 10,  # mg/dL to mg/L\\n        'mmol/L': 1.0,  # mmol/L to mg/L\\n    },\\n    'Magnesium': {\\n        'mmol/L': 2.43,  # mmol/L to mg/dL\\n        'mEq/L': 1.22,  # mEq/L to mg/dL\\n    },\\n    'Serum_Calcium': {\\n        'mmol/L': 4.008,  # mmol/L to mg/dL\\n        'mEq/L': 2.004,  # mEq/L to mg/dL\\n    },\\n    'Hemoglobin': {\\n        'g/L': 0.1,  # g/L to g/dL\\n        'mmol/L': 0.1551,  # mmol/L to g/dL\\n    },\\n    'Ferritin': {\\n        '\u00b5g/L': 1.0,  # \u00b5g/L to ng/mL\\n        'pmol/L': 0.0360,  # pmol/L to ng/mL\\n    },\\n    'Prealbumin': {\\n        'mg/L': 0.1,  # mg/L to mg/dL\\n        'g/L': 100,  # g/L to mg/dL\\n    },\\n    'Urine_Creatinine': {\\n        '\u00b5mol/L': 1 / 88.4,  # \u00b5mol/L to mg/dL\\n        'mmol/L': 88.4,  # mmol/L to mg/dL\\n    },\\n    'Troponin_I': {\\n        '\u00b5g/L': 1.0,  # \u00b5g/L to ng/mL\\n        'ng/L': 0.001,  # ng/L to ng/mL\\n    },\\n    'Troponin_T': {\\n        '\u00b5g/L': 1.0,  # \u00b5g/L to ng/mL\\n        'ng/L': 0.001,  # ng/L to ng/mL\\n    },\\n    'Albumin_Serum': {\\n        'g/L': 0.1,  # g/L to g/dL\\n    },\\n    'Total_Protein': {\\n        'g/L': 0.1,  # g/L to g/dL\\n    },\\n    'Aluminum': {\\n        'ng/mL': 1.0,  # ng/mL to \u00b5g/L (approximately)\\n        '\u00b5g/dL': 10,  # \u00b5g/dL to \u00b5g/L\\n    },\\n}\\n\\ndef clean_value(val):\\n    \\\"\\\"\\\"Convert string value to float, handling scientific notation and comma decimals\\\"\\\"\\\"\\n    if pd.isna(val) or val == '':\\n        return np.nan\\n    \\n    val_str = str(val).strip()\\n    \\n    if val_str == '' or val_str.lower() in ['nan', 'none', 'null']:\\n        return np.nan\\n    \\n    # Replace comma with period (European decimal format)\\n    val_str = val_str.replace(',', '.')\\n    \\n    try:\\n        return float(val_str)\\n    except ValueError:\\n        return np.nan\\n\\ndef detect_and_convert_unit(feature, value):\\n    \\\"\\\"\\\"Detect if value is in alternative unit and convert to US conventional\\\"\\\"\\\"\\n    if feature not in physiological_ranges or pd.isna(value):\\n        return value\\n    \\n    min_range, max_range = physiological_ranges[feature]\\n    \\n    # If value is within range, no conversion needed\\n    if min_range <= value <= max_range:\\n        return value\\n    \\n    # If value is outside range, try conversions\\n    if feature in conversion_factors:\\n        best_conversion = value\\n        best_distance = abs(value - min_range) if value < min_range else abs(value - max_range)\\n        \\n        for alt_unit, factor in conversion_factors[feature].items():\\n            converted = value * factor\\n            # Check if converted value is in range\\n            if min_range <= converted <= max_range:\\n                return converted\\n            # Otherwise track the closest conversion\\n            dist = abs(converted - min_range) if converted < min_range else abs(converted - max_range)\\n            if dist < best_distance:\\n                best_distance = dist\\n                best_conversion = converted\\n        \\n        return best_conversion\\n    \\n    # If no conversions available, return original\\n    return value\\n\\n# Step 2: Clean and convert all numeric values\\nprint(\\\"\\\\nStep 2: Cleaning and converting values...\\\")\\nnumeric_cols = [col for col in df.columns if col != 'patient_id']\\n\\nfor col in numeric_cols:\\n    # Clean values\\n    df[col] = df[col].apply(clean_value)\\n    \\n    # Detect and convert units\\n    df[col] = df[col].apply(lambda x: detect_and_convert_unit(col, x))\\n    \\n    # Round to 2 decimal places\\n    df[col] = df[col].round(2)\\n\\nprint(f\\\"Cleaned {len(numeric_cols)} numeric columns\\\")\\n\\n# Step 3: Format all values as X.XX\\nprint(\\\"\\\\nStep 3: Formatting values to X.XX format...\\\")\\nfor col in numeric_cols:\\n    df[col] = df[col].apply(lambda x: f\\\"{x:.2f}\\\" if pd.notna(x) else \\\"\\\")\\n\\n# Step 4: Save output\\nprint(\\\"\\\\nStep 4: Saving harmonized data...\\\")\\ndf.to_csv('/root/ckd_lab_data_harmonized.csv', index=False)\\nprint(f\\\"Saved to /root/ckd_lab_data_harmonized.csv\\\")\\nprint(f\\\"Final shape: {df.shape}\\\")\\n\\nEOFIMPROVED\\n\",\n      \"duration\": 0.5\n    },\n    {\n      \"keystrokes\": \"python3 /tmp/harmonize_improved.py\\n\",\n      \"duration\": 3.0\n    }\n  ]\n}\n```"
